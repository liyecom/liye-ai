{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liye.ai/contracts/governance/v1/gov_tool_call_request_v1.schema.json",
  "title": "GovToolCallRequestV1",
  "description": "Request for a governed tool call from OpenClaw to LiYe Gateway",
  "type": "object",
  "required": [
    "version",
    "trace_id",
    "idempotency_key",
    "tenant_id",
    "task",
    "policy_version",
    "proposed_actions",
    "context"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "GOV_TOOL_CALL_REQUEST_V1"
    },
    "trace_id": {
      "type": "string",
      "description": "Unique trace ID for end-to-end tracking"
    },
    "idempotency_key": {
      "type": "string",
      "description": "Idempotency key for retry safety"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant identifier (e.g., slack:T1234)"
    },
    "task": {
      "type": "string",
      "description": "User's original task text"
    },
    "policy_version": {
      "type": "string",
      "description": "Policy version for governance rules",
      "pattern": "^phase[0-9]+-v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "proposed_actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": ["action_type", "tool", "arguments"],
        "properties": {
          "action_type": {
            "type": "string",
            "enum": ["read"]
          },
          "tool": {
            "type": "string",
            "enum": ["amazon://strategy/wasted-spend-detect"]
          },
          "arguments": {
            "type": "object",
            "properties": {
              "start_date": {
                "type": "string",
                "format": "date"
              },
              "end_date": {
                "type": "string",
                "format": "date"
              },
              "min_spend": {
                "type": "number",
                "minimum": 0
              },
              "min_clicks": {
                "type": "integer",
                "minimum": 0
              },
              "max_rows": {
                "type": "integer",
                "minimum": 1,
                "maximum": 100
              }
            },
            "required": ["start_date", "end_date"]
          }
        }
      }
    },
    "context": {
      "type": "object",
      "required": ["source", "channel", "session_id", "user_id", "message_id"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["openclaw"]
        },
        "channel": {
          "type": "string",
          "enum": ["slack"]
        },
        "session_id": {
          "type": "string"
        },
        "user_id": {
          "type": "string"
        },
        "message_id": {
          "type": "string"
        }
      }
    }
  }
}
