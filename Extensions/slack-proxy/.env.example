# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
SLACK_SIGNING_SECRET=your-signing-secret-optional

# LiYe Gateway Configuration
LIYE_GATEWAY_WS=ws://localhost:3210/ws
LIYE_HMAC_SECRET=your-shared-hmac-secret-at-least-16-chars
LIYE_POLICY_VERSION=phase1-v1.0.0

# Optional: HTTP Proxy (respects standard env vars)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1,.internal.corp

# Optional: Slack Update Throttling (defaults shown)
# SLACK_UPDATE_MIN_INTERVAL_MS=900
# SLACK_PROGRESS_STEP=10
# SLACK_MAX_UPDATES_PER_JOB=30

# Optional: WebSocket Resilience (defaults shown)
# WS_RECONNECT_MAX=3
# WS_RECONNECT_BASE_DELAY_MS=500
