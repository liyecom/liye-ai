{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "automation-log entry",
  "description": "Single line in ~/.local/state/liye-automation/automation-log.jsonl",
  "type": "object",
  "required": ["ts", "action", "layer"],
  "properties": {
    "ts": {"type": "string", "format": "date-time"},
    "session_id": {"type": ["string", "null"]},
    "break_glass_id": {"type": ["string", "null"]},
    "layer": {"enum": ["L0", "L1", "L2", "L3", "init", "cleanup"]},
    "action": {"type": "string"},
    "tool": {"type": ["string", "null"]},
    "target_path": {"type": ["string", "null"]},
    "target_class": {"type": ["string", "null"]},
    "repo": {"type": ["string", "null"]},
    "branch": {"type": ["string", "null"]},
    "decision": {"enum": ["allow", "block", "warn", "advisory", null]},
    "decision_reason": {"type": ["string", "null"]},
    "redacted_fingerprints": {"type": ["array", "null"], "items": {"type": "string"}},
    "kind": {"type": ["string", "null"]},
    "secret_type": {"type": ["string", "null"]},
    "sha256_12": {"type": ["string", "null"]},
    "exp_utc": {"type": ["string", "null"]},
    "status": {"type": ["string", "null"]},
    "source": {"type": ["string", "null"]},
    "action_taken": {"type": ["string", "null"]},
    "rotate_required": {"type": ["boolean", "null"]},
    "rotation_guidance": {"type": ["string", "null"]},
    "note": {"type": ["string", "null"]},
    "actor_id": {"type": ["string", "null"]},
    "prefix": {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
